#include <bits/stdc++.h>
using namespace std;

int n, x,ans;
int t[1001];
int dp[101][1001]; // adjust sizes based on constraints

int rec(int level,int item_taken){
 if(level==n){
        if(x==item_taken) return 1;
        else return 0;
    }
    // cache check
    if (dp[level][item_taken] != -1)
        return dp[level][item_taken];

    // option 1: skip current item
    if(rec(level+1,item_taken)==1) ans=1;

    // option 2: take current item 
    else if(rec(level+1,item_taken+t[level])==1) ans=1;
      
      
    // save and return
    return dp[level][item_taken] = ans;
}

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    cin >> n >> x;
    for (int i = 0; i < n; i++) {
        cin >> t[i] ;
    }

    memset(dp, -1, sizeof(dp));
    cout << rec(0, 0) << "\n";

    return 0;
}
